# =============================================================================
# solana-token-monitor — environment variables
# =============================================================================
# This file is a template. Copy it to .env and fill in your own values.
# Never commit .env to git — it is already in .gitignore.
# Every value here belongs to YOU. Nothing in this repo is pre-filled.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# YOUR TOKEN (required)
# ─────────────────────────────────────────────────────────────────────────────
TOKEN_MINT=        # your SPL token mint address (base58)
TOKEN_SYMBOL=      # ticker, e.g. MYTOKEN
TOKEN_NAME=        # full name, e.g. My Token

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE (required)
# Get these from your Supabase project: Settings → API
# Note: inside Edge Functions, SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY
# are injected automatically. You only need these for local development
# or running x_poster.py.
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=               # https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=  # service_role key (keep this secret)

# ─────────────────────────────────────────────────────────────────────────────
# AI PROVIDERS (all optional — pick one, several, or none)
# If none are set the monitor uses templates and still works perfectly.
# Set AI_PRIMARY_PROVIDER to your preferred model.
# Set AI_PROVIDER_PREFERENCE for full fallback order (comma-separated).
# Valid values: grok, openai, nemotron, template
# Default order if unset: grok,openai,nemotron,template
# ─────────────────────────────────────────────────────────────────────────────
AI_PRIMARY_PROVIDER=        # your preferred provider: grok | openai | nemotron
AI_PROVIDER_PREFERENCE=     # fallback order, e.g. openai,nemotron,grok,template

GROK_API_KEY=               # console.x.ai → API Keys
OPENAI_API_KEY=             # platform.openai.com → API Keys
NEMOTRON_API_KEY=           # build.nvidia.com → Get API Key

# ─────────────────────────────────────────────────────────────────────────────
# DATA SOURCES (all optional — more keys = better data quality)
# DEXScreener requires no key. Everything else fills in the gaps.
# ─────────────────────────────────────────────────────────────────────────────
BIRDEYE_API_KEY=            # birdeye.so → Dashboard → API Keys (free tier works)
SOLSCAN_API_KEY=            # pro.solscan.io → API (free tier works)
X_BEARER_TOKEN=             # developer.twitter.com → App → Bearer Token

# ─────────────────────────────────────────────────────────────────────────────
# TELEGRAM (optional — enables all bot posting)
# ─────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=         # from @BotFather → /newbot
TELEGRAM_CHAT_ID=           # public channel or group id
TELEGRAM_OPS_CHAT_ID=       # private ops group (falls back to above if unset)

# ─────────────────────────────────────────────────────────────────────────────
# X / TWITTER OAUTH (optional — only needed to run scripts/x_poster.py)
# ─────────────────────────────────────────────────────────────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
