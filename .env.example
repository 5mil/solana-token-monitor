# ─────────────────────────────────────────────────────────────────────────────
# solana-token-monitor
# Copy to .env — never commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# your token (required)
TOKEN_MINT=YOUR_SPL_TOKEN_MINT_ADDRESS
TOKEN_SYMBOL=TOKEN
TOKEN_NAME=Your Token Name

# supabase (required)
# dashboard → project settings → api
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# data sources (all optional, more = better data quality)
BIRDEYE_API_KEY=        # birdeye.so → dashboard → api keys
SOLSCAN_API_KEY=        # pro.solscan.io → api
X_BEARER_TOKEN=         # developer.twitter.com → app → bearer token

# telegram (optional — enables all bot posting)
TELEGRAM_BOT_TOKEN=     # from @BotFather → /newbot
TELEGRAM_CHAT_ID=       # public channel or group id (negative number)
TELEGRAM_OPS_CHAT_ID=   # private ops group — falls back to above if unset

# ai providers (all optional — pick one, or none for template mode)
# grok is recommended: fast, cheap, understands crypto context well
GROK_API_KEY=           # console.x.ai → api keys
OPENAI_API_KEY=         # platform.openai.com → api keys
NEMOTRON_API_KEY=       # build.nvidia.com → get api key

# x/twitter oauth (optional — only needed to run x_poster.py)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
